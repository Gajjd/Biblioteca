@model Biblioteca.Models.EditarAutorViewModel

@{
    ViewData["Title"] = "Editar Autor";
}

<div class="container mt-4">
    <h1>Editar Autor</h1>

    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="EditarAutor" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label asp-for="Nome" class="control-label">
                        Título do Livro
                    </label>

                    <input asp-for="Nome" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Nacionalidade" class="control-label">
                        Nacionalidade
                    </label>

                    <input asp-for="Nacionalidade" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Nascimento" class="control-label">
                        Nascimento
                    </label>

                    <input asp-for="Nascimento" 
                           type="date" 
                           class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Morte" class="control-label">
                        Morte
                    </label>

                    <input asp-for="Morte" 
                           type="date" 
                           class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Biografia" class="control-label">
                        Biografia
                    </label>

                    <input asp-for="Biografia" class="form-control" />
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">
                        Salvar Alterações
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>